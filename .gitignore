# The seed DATA stays out of git — referee_coaches.json holds real names and
# emails. The schema script itself has no secrets (it reads credentials from the
# env) and drifted twice between laptop and host in one afternoon, each time
# leaving production silently missing a column. Tracked on purpose.
deploy/hetzner/seed/*
!deploy/hetzner/seed/setup-schema.mjs
deploy/hetzner/svrz-api.env
deploy/hetzner/pb_data/
deploy/hetzner/.env

# Activity log written by the API (server/logstore.ts): ./logs locally,
# deploy/hetzner/logs on the host via the compose bind mount.
logs/

# stray one-off scripts
*.tmp.mjs

# Playwright output
playwright-report/
test-results/

# Agent worktrees and local Claude settings
.claude/
