# Pinned PocketBase server. Set PB_VERSION to the value printed by the backup
# step (`pocketbase --version` on the old VPS) so pb_data stays compatible.
FROM alpine:3.20
ARG PB_VERSION=0.22.21
RUN apk add --no-cache ca-certificates unzip wget && \
    wget -O /tmp/pb.zip "https://github.com/pocketbase/pocketbase/releases/download/v${PB_VERSION}/pocketbase_${PB_VERSION}_linux_amd64.zip" && \
    unzip /tmp/pb.zip -d /pb
EXPOSE 8090
ENTRYPOINT ["/pb/pocketbase", "serve", "--http=0.0.0.0:8090", "--dir=/pb/pb_data"]
