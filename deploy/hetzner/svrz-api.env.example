# Copy your RESTORED .env.local from the old VPS here as svrz-api.env.
POCKETBASE_URL=http://pocketbase:8090
POCKETBASE_ADMIN_EMAIL=__from_old_env__
POCKETBASE_ADMIN_PASSWORD=__from_old_env__
ADMIN_SESSION_SECRET=__from_old_env__
VM_USERNAME=__from_old_env__
VM_PASSWORD=__from_old_env__
VM_BASE=__from_old_env__
# The code reads VM_SYNC_CRON / VM_SYNC_TIMEZONE. Named SYNC_* these two were
# dead: editing them changed nothing, silently.
VM_SYNC_CRON=0 5 * * *
VM_SYNC_TIMEZONE=Europe/Zurich
SMTP_HOST=smtp.migadu.com
# Hetzner blocks outbound 25/465 by default — use 587 (STARTTLS) here.
SMTP_PORT=587
SMTP_USER=__from_old_env__
SMTP_PASS=__from_old_env__
SMTP_FROM=no-reply@example.com
# BCC for the feedback report (PDF). Comma-separated for more than one mailbox.
FEEDBACK_CC=your-coaching-inbox@example.com,rc-commission@example.com
# Redirects every feedback report to FEEDBACK_TEST_RECIPIENT instead of the
# referee. Ships off: the redirect only applies when BOTH are set, so a 1 here
# with the placeholder recipient below sends live coaching mail to a literal
# "__your_test_email__" — and a 1 with the recipient blank falls through and
# mails the real referee, which is the opposite of what a test flag implies.
FEEDBACK_EMAIL_TEST=0
FEEDBACK_TEST_RECIPIENT=__your_test_email__
# NOTE: who may READ the survey responses is NOT configured here. It is the
# is_rc_president flag on her referee_coaches record, set directly in PocketBase
# — deliberately not exposed in the admin console, since a flag an admin can
# tick is a flag an admin can tick for themselves. Admin rights do not open it.
#
# Where each submitted survey is mailed as it arrives (comma-separated).
# Receiving them and reading the collected set in the tool are different jobs.
# Unset = stored only, no mail.
SURVEY_NOTIFY_EMAIL=rekom-inbox@example.com
# Base the calendar subscription links are built from. Leave UNSET: it is then
# derived from the request, which is correct behind the tunnel. Setting it to
# the wrong host mints calendar subscriptions that 404 — and copying a stale
# value from this file is exactly how that happens. Set it only if a subscriber
# is ever handed a wrong host, and to the CURRENT API origin.
# API_PUBLIC_URL=https://svrz-rc-api.openvolley.app
# Bumping this invalidates every existing calendar subscription (all must
# re-subscribe). Normally left alone.
ICAL_TOKEN_VERSION=1
# --- added by security hardening ---
ADMIN_UI_PASSWORD=change-me
# Origins allowed to call this API. Anything else is rejected before the route
# runs and shows up in the browser as a bare "Failed to fetch". During the
# Cloudflare Pages cutover keep BOTH the new and old origins listed, then drop
# the retired one once no traffic arrives from it.
CORS_ALLOWED_ORIGINS=https://svrz-rc.openvolley.app
# Where every outbound mail points ("Zur App", PIN mails, survey links) and the
# URL stamped into calendar entries. A stale value here mails coaches a link to
# a domain that no longer serves the app.
APP_PUBLIC_URL=https://svrz-rc.openvolley.app/
# 'lax' or 'none'. Only set 'lax' once this API is served from a hostname under
# the SAME registrable domain as the app (svrz-rc-api.openvolley.app alongside
# svrz-rc.openvolley.app). Lax then stops the session cookie being third-party,
# which is what makes login work in Safari. Setting 'lax' while the API is on a
# different site logs everyone out.
SESSION_COOKIE_SAMESITE=none
# Suppresses EVERY outbound mail — PIN, password reset, feedback, reminders —
# while the UI still reports them as sent. Ships off; turn it on deliberately.
TEST_MODE=0
