# Copy your RESTORED .env.local from the old VPS here as svrz-api.env.
POCKETBASE_URL=http://pocketbase:8090
POCKETBASE_ADMIN_EMAIL=__from_old_env__
POCKETBASE_ADMIN_PASSWORD=__from_old_env__
ADMIN_SESSION_SECRET=__from_old_env__
VM_USERNAME=__from_old_env__
VM_PASSWORD=__from_old_env__
VM_BASE=__from_old_env__
VM_SYNC_CRON=0 5 * * *
VM_SYNC_TIMEZONE=Europe/Zurich
SMTP_HOST=smtp.migadu.com
# Hetzner blocks outbound 25/465 by default — use 587 (STARTTLS) here.
SMTP_PORT=587
SMTP_USER=__from_old_env__
SMTP_PASS=__from_old_env__
SMTP_FROM=no-reply@example.com
# BCC for the feedback report (PDF). Comma-separated for more than one mailbox.
FEEDBACK_CC=your-coaching-inbox@example.com,rc-commission@example.com
FEEDBACK_EMAIL_TEST=1
FEEDBACK_TEST_RECIPIENT=__your_test_email__
# NOTE: who may READ the survey responses is NOT configured here. It is the
# is_rc_president flag on her referee_coaches record, set directly in PocketBase
# — deliberately not exposed in the admin console, since a flag an admin can
# tick is a flag an admin can tick for themselves. Admin rights do not open it.
#
# Where each submitted survey is mailed as it arrives (comma-separated).
# Receiving them and reading the collected set in the tool are different jobs.
# Unset = stored only, no mail.
SURVEY_NOTIFY_EMAIL=rekom-inbox@example.com
# Base the calendar subscription links are built from. Unset = derived from the
# request, which is correct behind the tunnel; set it only if a subscriber ever
# gets handed a wrong host. Bumping ICAL_TOKEN_VERSION invalidates every
# existing subscription — everyone then has to re-subscribe.
API_PUBLIC_URL=https://rc-api.example.com
ICAL_TOKEN_VERSION=1
# --- added by security hardening ---
ADMIN_UI_PASSWORD=change-me
CORS_ALLOWED_ORIGINS=https://lucanepa.github.io
TEST_MODE=1
