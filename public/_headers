# Cloudflare Pages response headers. Copied verbatim into dist/ by Vite.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()

# Vite fingerprints everything under /assets, so it can be cached forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# The service worker and the shell must NOT be cached at the edge or in the
# browser: a stale sw.js is how a PWA pins itself to a dead build. This is the
# same trap that made the retired GitHub Pages deployment need a kill switch.
/sw.js
  Cache-Control: no-cache
/registerSW.js
  Cache-Control: no-cache
/
  Cache-Control: no-cache
/index.html
  Cache-Control: no-cache
/manifest.webmanifest
  Cache-Control: no-cache
